# Renomeie para .env.local e preencha. NUNCA commite o .env.local.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site URL (para redirecionamento do magic link)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API-Football (api-sports.io ou RapidAPI)
API_FOOTBALL_KEY=

# Cron secret — protege o endpoint /api/rounds/auto-close de chamadas externas
# Gere um valor aleatório: openssl rand -hex 32
CRON_SECRET=
